# ══════════════════════════════════════════════════
# libmpv-prebuilt version configuration
# Single source of truth — edit ONLY this file
# ══════════════════════════════════════════════════

# Release tag for THIS repo's output
RELEASE_VERSION=2026.04.26

# ── Sources we BUILD from ──
MPV_ANDROID_REPO=mpv-android/mpv-android
MPV_ANDROID_REF=master

# ── Android NDK Configuration ──
# CRITICAL: Frozen NDK version for reproducible C++ runtime (libc++)
# Using fixed NDK ensures all builds use matching libc++_shared.so
# Changes to NDK version are HIGH-IMPACT and must be coordinated with consumers
ANDROID_NDK_VERSION=r27c
ANDROID_STL=c++_shared

MPV_BUILD_REPO=mpv-player/mpv-build
MPV_BUILD_REF=master

# ── Sources we DOWNLOAD prebuilts from ──
SHINCHIRO_REPO=shinchiro/mpv-winbuild-cmake
SHINCHIRO_TAG=latest

DARWIN_REPO=media-kit/libmpv-darwin-build
DARWIN_TAG=v0.6.2