# ══════════════════════════════════════════════════
# libmpv-prebuilt version configuration
# Edit ONLY this file to change versions
# ══════════════════════════════════════════════════

# Release tag for THIS repo's output
RELEASE_VERSION=2026.04.26

# ── Sources we BUILD from ──
# mpv-android buildscripts (Android)
MPV_ANDROID_REPO=mpv-android/mpv-android
MPV_ANDROID_REF=master

# mpv-build (Linux)
MPV_BUILD_REPO=mpv-player/mpv-build
MPV_BUILD_REF=master

# ── Sources we DOWNLOAD prebuilts from ──
# shinchiro Windows builds
SHINCHIRO_REPO=shinchiro/mpv-winbuild-cmake
SHINCHIRO_TAG=latest
# Fallback: specific tag like 20260421

# media-kit Darwin builds (macOS + iOS)
DARWIN_REPO=media-kit/libmpv-darwin-build
DARWIN_TAG=v0.6.2

# ── Archive naming ──
# Format: libmpv-{PLATFORM}-{ARCH}.tar.gz
# Examples:
#   libmpv-android-arm64-v8a.tar.gz
#   libmpv-android-armeabi-v7a.tar.gz
#   libmpv-android-x86_64.tar.gz
#   libmpv-android-x86.tar.gz
#   libmpv-linux-x86_64.tar.gz
#   libmpv-windows-x86_64.tar.gz
#   libmpv-windows-aarch64.tar.gz
#   libmpv-macos-arm64.tar.gz
#   libmpv-macos-x86_64.tar.gz
#   libmpv-ios-arm64.tar.gz
#   libmpv-iossimulator-arm64.tar.gz
#   libmpv-iossimulator-x86_64.tar.gz

# ── Archive internal structure (all platforms) ──
# lib/          → .so / .dll / .dylib / .a / .framework
# include/mpv/  → client.h, render.h, render_gl.h, stream_cb.h
# NOTICE.md     → attribution